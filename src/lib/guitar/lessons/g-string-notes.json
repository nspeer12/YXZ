{
  "id": "g-string-notes",
  "title": "Notes on the G string",
  "description": "Learn the natural notes along the 3rd string: G, A, B, C, D, E, F, G.",
  "category": "notes",
  "difficulty": "beginner",
  "tuning": "standard",
  "passAccuracy": 0.7,
  "prerequisites": ["d-string-notes"],
  "exercises": [
    {
      "id": "ascend",
      "title": "Ascend the G string",
      "instruction": "Use one finger per fret. Open G, A (2), B (4), C (5), D (7), E (9), F (10), G (12).",
      "bpm": 60,
      "targets": [
        { "id": "n0", "string": 3, "fret": 0, "beat": 0, "duration": 1, "label": "G (open)" },
        { "id": "n1", "string": 3, "fret": 2, "beat": 1, "duration": 1, "label": "A" },
        { "id": "n2", "string": 3, "fret": 4, "beat": 2, "duration": 1, "label": "B" },
        { "id": "n3", "string": 3, "fret": 5, "beat": 3, "duration": 1, "label": "C" },
        { "id": "n4", "string": 3, "fret": 7, "beat": 4, "duration": 1, "label": "D" },
        { "id": "n5", "string": 3, "fret": 9, "beat": 5, "duration": 1, "label": "E" },
        { "id": "n6", "string": 3, "fret": 10, "beat": 6, "duration": 1, "label": "F" },
        { "id": "n7", "string": 3, "fret": 12, "beat": 7, "duration": 1, "label": "G (octave)" }
      ]
    },
    {
      "id": "descend",
      "title": "Back down the G string",
      "bpm": 60,
      "targets": [
        { "id": "n7", "string": 3, "fret": 12, "beat": 0, "duration": 1, "label": "G (octave)" },
        { "id": "n6", "string": 3, "fret": 10, "beat": 1, "duration": 1, "label": "F" },
        { "id": "n5", "string": 3, "fret": 9, "beat": 2, "duration": 1, "label": "E" },
        { "id": "n4", "string": 3, "fret": 7, "beat": 3, "duration": 1, "label": "D" },
        { "id": "n3", "string": 3, "fret": 5, "beat": 4, "duration": 1, "label": "C" },
        { "id": "n2", "string": 3, "fret": 4, "beat": 5, "duration": 1, "label": "B" },
        { "id": "n1", "string": 3, "fret": 2, "beat": 6, "duration": 1, "label": "A" },
        { "id": "n0", "string": 3, "fret": 0, "beat": 7, "duration": 1, "label": "G (open)" }
      ]
    }
  ]
}
