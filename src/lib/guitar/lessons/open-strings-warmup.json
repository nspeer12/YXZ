{
  "id": "open-strings-warmup",
  "title": "Open strings warm-up",
  "description": "Pluck each open string in time with the metronome. Builds picking accuracy.",
  "category": "notes",
  "difficulty": "starter",
  "tuning": "standard",
  "passAccuracy": 0.7,
  "prerequisites": [],
