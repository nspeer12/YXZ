{
  "id": "a-string-notes",
  "title": "Notes on the A string",
  "description": "Learn the natural notes along the 5th string: A, B, C, D, E, F, G, A.",
  "category": "notes",
  "difficulty": "beginner",
  "tuning": "standard",
  "passAccuracy": 0.7,
  "prerequisites": ["low-e-notes"],
  "exercises": [
    {
      "id": "ascend",
      "title": "Ascend the A string",
      "instruction": "Use one finger per fret. Open A, B (2), C (3), D (5), E (7), F (8), G (10), A (12).",
      "bpm": 60,
      "targets": [
        { "id": "n0", "string": 1, "fret": 0, "beat": 0, "duration": 1, "label": "A (open)" },
        { "id": "n1", "string": 1, "fret": 2, "beat": 1, "duration": 1, "label": "B" },
        { "id": "n2", "string": 1, "fret": 3, "beat": 2, "duration": 1, "label": "C" },
        { "id": "n3", "string": 1, "fret": 5, "beat": 3, "duration": 1, "label": "D" },
        { "id": "n4", "string": 1, "fret": 7, "beat": 4, "duration": 1, "label": "E" },
        { "id": "n5", "string": 1, "fret": 8, "beat": 5, "duration": 1, "label": "F" },
        { "id": "n6", "string": 1, "fret": 10, "beat": 6, "duration": 1, "label": "G" },
        { "id": "n7", "string": 1, "fret": 12, "beat": 7, "duration": 1, "label": "A (octave)" }
      ]
    },
    {
      "id": "descend",
      "title": "Back down the A string",
      "bpm": 60,
      "targets": [
        { "id": "n7", "string": 1, "fret": 12, "beat": 0, "duration": 1, "label": "A (octave)" },
        { "id": "n6", "string": 1, "fret": 10, "beat": 1, "duration": 1, "label": "G" },
        { "id": "n5", "string": 1, "fret": 8, "beat": 2, "duration": 1, "label": "F" },
        { "id": "n4", "string": 1, "fret": 7, "beat": 3, "duration": 1, "label": "E" },
        { "id": "n3", "string": 1, "fret": 5, "beat": 4, "duration": 1, "label": "D" },
        { "id": "n2", "string": 1, "fret": 3, "beat": 5, "duration": 1, "label": "C" },
        { "id": "n1", "string": 1, "fret": 2, "beat": 6, "duration": 1, "label": "B" },
        { "id": "n0", "string": 1, "fret": 0, "beat": 7, "duration": 1, "label": "A (open)" }
      ]
    }
  ]
}
