      "bpm": 70,
      "targets": [
        { "id": "c1", "string": 1, "fret": 3, "beat": 0, "duration": 1, "label": "C", "chord": [{ "string": 1, "fret": 3 }, { "string": 2, "fret": 2 }, { "string": 3, "fret": 0 }, { "string": 4, "fret": 1 }, { "string": 5, "fret": 0 }] },
        { "id": "c2", "string": 1, "fret": 3, "beat": 1, "duration": 1, "label": "C", "chord": [{ "string": 1, "fret": 3 }, { "string": 2, "fret": 2 }, { "string": 3, "fret": 0 }, { "string": 4, "fret": 1 }, { "string": 5, "fret": 0 }] },
