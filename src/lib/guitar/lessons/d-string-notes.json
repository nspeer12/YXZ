{
  "id": "d-string-notes",
  "title": "Notes on the D string",
  "description": "Learn the natural notes along the 4th string: D, E, F, G, A, B, C, D.",
  "category": "notes",
  "difficulty": "beginner",
  "tuning": "standard",
  "passAccuracy": 0.7,
  "prerequisites": ["a-string-notes"],
  "exercises": [
    {
      "id": "ascend",
      "title": "Ascend the D string",
      "instruction": "Use one finger per fret. Open D, E (2), F (3), G (5), A (7), B (9), C (10), D (12).",
      "bpm": 60,
      "targets": [
        { "id": "n0", "string": 2, "fret": 0, "beat": 0, "duration": 1, "label": "D (open)" },
        { "id": "n1", "string": 2, "fret": 2, "beat": 1, "duration": 1, "label": "E" },
        { "id": "n2", "string": 2, "fret": 3, "beat": 2, "duration": 1, "label": "F" },
        { "id": "n3", "string": 2, "fret": 5, "beat": 3, "duration": 1, "label": "G" },
        { "id": "n4", "string": 2, "fret": 7, "beat": 4, "duration": 1, "label": "A" },
        { "id": "n5", "string": 2, "fret": 9, "beat": 5, "duration": 1, "label": "B" },
        { "id": "n6", "string": 2, "fret": 10, "beat": 6, "duration": 1, "label": "C" },
        { "id": "n7", "string": 2, "fret": 12, "beat": 7, "duration": 1, "label": "D (octave)" }
      ]
    },
    {
      "id": "descend",
      "title": "Back down the D string",
      "bpm": 60,
      "targets": [
        { "id": "n7", "string": 2, "fret": 12, "beat": 0, "duration": 1, "label": "D (octave)" },
        { "id": "n6", "string": 2, "fret": 10, "beat": 1, "duration": 1, "label": "C" },
        { "id": "n5", "string": 2, "fret": 9, "beat": 2, "duration": 1, "label": "B" },
        { "id": "n4", "string": 2, "fret": 7, "beat": 3, "duration": 1, "label": "A" },
        { "id": "n3", "string": 2, "fret": 5, "beat": 4, "duration": 1, "label": "G" },
        { "id": "n2", "string": 2, "fret": 3, "beat": 5, "duration": 1, "label": "F" },
        { "id": "n1", "string": 2, "fret": 2, "beat": 6, "duration": 1, "label": "E" },
        { "id": "n0", "string": 2, "fret": 0, "beat": 7, "duration": 1, "label": "D (open)" }
      ]
    }
  ]
}
